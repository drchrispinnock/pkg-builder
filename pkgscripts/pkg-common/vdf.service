[Unit]
Description=octez-vdf
Documentation=https://tezos.gitlab.io/
After=network.target

[Service]
User=tezos
Group=tezos
WorkingDirectory=~
Restart=on-failure
RestartSec=10s
KillMode=control-group
TimeoutStartSec=30s
TimeoutStopSec=300s

ExecStart=/usr/bin/octez-baker run vdf -K
Slice=octez.slice

StandardOutput=append:/var/log/tezos/octez-vdf.log
StandardError=inherit

[Install]
WantedBy=multi-user.target
