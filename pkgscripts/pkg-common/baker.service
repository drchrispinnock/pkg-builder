[Unit]
Description=octez-baker
Documentation=https://tezos.gitlab.io/
After=network.target

[Service]
Environment="LQ_VOTE=break DATADIR=/var/tezos/.tezos-node DAL_OPTIONS="--without-dal" USER=tezos LOGDIR=/var/log/tezos"
EnvironmentFile=-/etc/default/octez-baker
User=$USER
WorkingDirectory=~
Restart=on-failure
RestartSec=10s
KillMode=control-group
TimeoutStartSec=30s
TimeoutStopSec=300s

ExecStart=/usr/bin/octez-baker run with local node $DATADIR -K --liquidity-baking-toggle-vote $LQ_VOTE $RUNTIME_OPTS $DAL_OPTIONS
Slice=octez.slice

[Install]
WantedBy=multi-user.target
