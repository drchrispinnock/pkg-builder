[Unit]
Description=octez-accuser
Documentation=https://tezos.gitlab.io/
After=network.target

[Service]
Environment="USER=tezos LOGDIR=/var/log/tezos"
EnvironmentFile=-/etc/default/octez-baker
User=$USER
WorkingDirectory=~
Restart=on-failure
RestartSec=10s
KillMode=control-group
TimeoutStartSec=30s
TimeoutStopSec=300s

ExecStart=/usr/bin/octez-accuser run -K $RUNTIME_OPTS
Slice=octez.slice

[Install]
WantedBy=multi-user.target
