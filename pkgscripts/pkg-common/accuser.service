[Unit]
Description=octez-accuser
Documentation=https://tezos.gitlab.io/
After=network.target

[Service]
EnvironmentFile=-/etc/default/octez-accuser
User=tezos
Group=tezos
WorkingDirectory=~
Restart=on-failure
RestartSec=10s
KillMode=control-group
TimeoutStartSec=30s
TimeoutStopSec=300s

ExecStart=/usr/bin/octez-accuser run -K $RUNTIME_OPTS
Slice=octez.slice

StandardOutput=append:/var/log/tezos/accuser.log
StandardError=inherit

[Install]
WantedBy=multi-user.target
