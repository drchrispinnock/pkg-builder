#!/bin/sh

user=tezos
group=tezos
homedir=/var/tezos

# Ensure the tezos user is created
getent group ${group} >/dev/null 2>&1 || addgroup ${group}
getent passwd ${user} >/dev/null 2>&1 || adduser --home $homedir \
            --gecos "tezos signer" \
						--shell /bin/bash \
						--disabled-password \
						--ingroup ${group} ${user}

if [ ! -d "${homedir}" ]; then
	mkdir -p "${homedir}"
	chown tezos:tezos "${homedir}"
fi


if [ ! -d "${logdir}" ]; then
	mkdir -p "${logdir}"
	chown tezos:tezos "${logdir}"
fi

# Reload to get new init scripts
/usr/bin/systemctl daemon-reload
