Name:		@PKG@
Version:	@VERSION@
Release:	@REVISION@
Summary:	The Octez Signer

Packager:   @MAINT@
License:	MIT
URL:		http://tezos.gitlab.io

Source0:	@FAKESRC@

%prep
%setup -q

%install
tar cpf - . | (cd $RPM_BUILD_ROOT && tar xpf -)

%description
The Octez Signer

%files
%{_bindir}/octez-*
%config %{_sysconfdir}/default/octez-signer
%{_unitdir}/octez-signer.service

%post
getent group tzsigner >/dev/null 2>&1 || groupadd tzsigner
getent passwd tzsigner >/dev/null 2>&1 || useradd -g tzsigner tzsigner
mkdir /var/tzsigner >/dev/null 2>&1 && chown tzsigner:tzsigner /var/tzsigner
mkdir -p /var/log/tezos
/usr/bin/systemctl daemon-reload
