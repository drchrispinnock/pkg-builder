Name:		@PKG@
Version:	@VERSION@
Release:	@REVISION@
Summary:	The Octez Baker daemons

License:	MIT
URL:		http://tezos.gitlab.io

Packager:	@MAINT@
Requires:	@DPKG@-node,@DPKG@-client
Source0:	@FAKESRC@

%prep
%setup -q

%install
tar cpf - . | (cd $RPM_BUILD_ROOT && tar xpf -)

%description
The Octez Baker daemons

%files
%{_bindir}/octez-*
%config %{_sysconfdir}/defaults/octez-baker
%{_unitdir}/octez-baker.service

%post
/usr/bin/systemctl daemon-reload
