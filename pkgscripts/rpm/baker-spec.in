Name:		@PKG@
Version:	@VERSION@
Release:	@REVISION@
Summary:	The Octez Baker daemons

License:	MIT
URL:		http://tezos.gitlab.io

Packager:	@MAINT@
Requires:	@DPKG@-node,@DPKG@-client
Source0:	@FAKESRC@

%prep
%setup -q

%install
tar cpf - . | (cd $RPM_BUILD_ROOT && tar xpf -)

%description
The Octez Baker daemons

%files
%{_bindir}/octez-*
%config %{_sysconfdir}/default/octez-baker
%{_unitdir}/octez-baker.service

%post
getent group tezos >/dev/null 2>&1 || groupadd tezos
getent passwd tezos >/dev/null 2>&1 || useradd -g tezos -d /var/tezos tezos
mkdir /var/tezos >/dev/null 2>&1 && chown tezos:tezos /var/tezos
mkdir -p /var/log/tezos
/usr/bin/systemctl daemon-reload
