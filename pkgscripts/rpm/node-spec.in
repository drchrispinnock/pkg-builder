Name:		@PKG@
Version:	@VERSION@
Release:	@REVISION@
Summary:	The Octez Node

Packager:   @MAINT@
License:	MIT
URL:		http://tezos.gitlab.io

Source0:	@FAKESRC@
Requires:	@DPKG@-zcash-params

%prep
%setup -q

%install
tar cpf - . | (cd $RPM_BUILD_ROOT && tar xpf -)

%description
The Octez Node daemons

%files
%{_bindir}/octez-*
%config %{_sysconfdir}/default/octez-node
%{_unitdir}/octez-node.service

%post
getent group tezos >/dev/null 2>&1 || groupadd tezos
getent passwd tezos >/dev/null 2>&1 || useradd -g tezos -d /var/tezos tezos
/usr/bin/systemctl daemon-reload
