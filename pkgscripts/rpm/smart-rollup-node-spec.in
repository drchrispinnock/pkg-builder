Name:		@PKG@
Version:	@VERSION@
Release:	@REVISION@
Summary:	The Octez Smart Rollup daemons

Packager:   @MAINT@
License:	MIT
URL:		http://tezos.gitlab.io

Source0:	@FAKESRC@

%prep
%setup -q

%install
tar cpf - . | (cd $RPM_BUILD_ROOT && tar xpf -)

%description
The Octez Smart Rollup daemons

%files
%{_bindir}/octez-*
%config %{_sysconfdir}/default/octez-smart-rollup-node
%{_unitdir}/octez-smart-rollup-node.service

%post
getent group tezos >/dev/null 2>&1 || groupadd tezos
getent passwd tezos >/dev/null 2>&1 || useradd -g tezos -d /var/tezos tezos
mkdir /var/tezos >/dev/null 2>&1 && chown tezos:tezos /var/tezos
mkdir -p /var/log/tezos
/usr/bin/systemctl daemon-reload
